{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Aws": {
    "Region": "us-east-1",
    "SecretsManager": {
      "SecretName": "amp-facebook-api/dev"
    }
  },
  "Jwt": {
    "Authority": "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_REPLACE",
    "ClientId": "REPLACE_CLIENT_ID",
    "RequireHttpsMetadata": false
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
