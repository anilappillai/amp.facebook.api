{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Aws": {
    "Region": "us-east-1",
    "SecretsManager": {
      "SecretName": "amp-facebook-api/config"
    }
  },
    "Facebook": {
    "GraphApiBaseUrl": "https://graph.facebook.com/v25.0/"
  },
  "Jwt": {
    "Authority": "",
    "Audience": "",
    "ClientId": "",
    "RequireHttpsMetadata": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.AwsCloudWatch" ],
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "Microsoft": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "AwsCloudWatch",
        "Args": {
          "logGroupName": "/aws/eks/amp-facebook-api",
          "logStreamPrefix": "amp-facebook-api",
          "createLogGroup": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "ApplicationName": "Amp.Facebook.Api"
    }
  }
}
